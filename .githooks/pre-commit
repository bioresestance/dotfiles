#!/usr/bin/env bash
set -euo pipefail

# Format staged .nix files before committing
staged_nix_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.nix')

if [[ -z "$staged_nix_files" ]]; then
  exit 0
fi

echo "Formatting staged Nix files..."
echo "$staged_nix_files" | xargs nixfmt

# Re-stage the formatted files
echo "$staged_nix_files" | xargs git add

echo "✓ Nix files formatted and re-staged"
